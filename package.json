{
  "name": "node-api-performance-validation",
  "version": "1.0.0",
  "description": "Risk Analysis & Simulation API for performance validation",
  "main": "dist/index.js",
  "scripts": {
    "build": "yarn build:rust && yarn build:zig && tsc",
    "build:rust": "cd ./src/native/rust && yarn build",
    "build:zig": "cd ./src/native/zig && zig build -Doptimize=ReleaseFast",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --stack-size=8192 --respawn --transpile-only --ignore-watch node_modules src/index.ts",
    "dev:ts": "LANG_MODEL=TS yarn dev",
    "dev:rs": "LANG_MODEL=RS yarn dev",
    "dev:zg": "LANG_MODEL=ZG yarn dev",
    "watch": "tsc --watch",
    "test:coverage": "vitest run --coverage",
    "native:install": "cd ./src/native/rust && yarn install",
    "native:build": "yarn build:rust && yarn build:zig",
    "native:build:rust": "cd ./src/native/rust && yarn build",
    "native:build:zig": "cd ./src/native/zig && zig build -Doptimize=ReleaseFast",
    "native:test": "cd ./src/native/rust && yarn test",
    "copy-native": "yarn copy-native:rust && yarn copy-native:zig",
    "copy-native:rust": "shx mkdir -p ./dist/native/rust && shx cp ./src/native/rust/index.js ./src/native/rust/index.d.ts ./src/native/rust/*.node ./dist/native/rust/",
    "copy-native:zig": "shx mkdir -p ./dist/native/zig/zig-out/lib && shx cp ./src/native/zig/index.js ./src/native/zig/index.d.ts ./dist/native/zig/ && shx cp ./src/native/zig/zig-out/lib/addon.node ./dist/native/zig/zig-out/lib/"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "yarn@4.9.1",
  "dependencies": {
    "express": "^4.18.2",
    "module-alias": "^2.2.3",
    "prom-client": "^15.1.0",
    "shx": "^0.4.0",
    "ts-node-dev": "^2.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/module-alias": "^2",
    "@types/node": "^20.10.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
