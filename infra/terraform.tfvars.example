# Required
# Set your DO token via environment for better security:
# export TF_VAR_do_token="dop_v1_xxx"

# Optional overrides
region              = "nyc1"
cluster_name        = "node-api-perf-cluster"
kubernetes_version  = ""  # optional; when empty Terraform uses latest supported DO slug
node_size           = "s-2vcpu-4gb"
node_count          = 2
